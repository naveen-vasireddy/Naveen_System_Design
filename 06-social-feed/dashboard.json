{
  "title": "Social Feed Service - Observability",
  "uid": "feed-observability-01",
  "tags": ["feed", "production"],
  "timezone": "browser",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "p95 Read Latency per Shard",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(feed_db_read_latency_ms_bucket[5m])) by (le, shard_id))",
          "legendFormat": "Shard {{shard_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Latency (ms)",
            "axisPlacement": "left"
          }
        }
      },
      "description": "Measures the 95th percentile read latency across all 4 database shards. Spikes indicate an overloaded shard or unoptimized query."
    },
    {
      "title": "Ranking Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(feed_cache_hits_total[5m])) / sum(rate(feed_cache_requests_total[5m])) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "description": "Percentage of feed reads served directly from the Redis Top N cache vs hitting the database."
    }
  ]
}